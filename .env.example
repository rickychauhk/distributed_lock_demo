# Redis (no default in prod - set explicitly)
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
# Set to 1 when behind a reverse proxy (nginx, etc.) so X-Forwarded-* is trusted
# TRUST_PROXY=0

# Lock TTL (seconds)
LOCK_TTL=30

# Idempotency cache TTL (seconds)
IDEMPOTENCY_TTL=300

# Simulation script only
API_BASE=http://localhost:3000
DEMO_SKU=SKU-001
CONCURRENT=100
